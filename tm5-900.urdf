<?xml version="1.0" ?>
<robot name="tm5-900">

  <link name="base"/>
  <joint name="base_fixed_joint" type="fixed">
    <parent link="base"/><child link="link_0"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <link name="link_0">
    <visual><geometry><mesh filename="package://tm_description/meshes/tm5-900/visual/tm5base.obj"/></geometry></visual>
    <collision><geometry><mesh filename="package://tm_description/meshes/tm5-900/collision/tm5base_c.stl"/></geometry></collision>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="link_0"/><child link="link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.1452"/><axis xyz="0 0 1"/>
    <limit effort="157" lower="-4.712389" upper="4.712389" velocity="3.14159"/>
  </joint>

  <link name="link_1">
