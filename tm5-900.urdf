    <collision><geometry><mesh filename="package://tm_description/meshes/tm5-900/collision/tmr_100w_01_c.stl"/></geometry></collision>
  </link>

  <joint name="joint_5" type="revolute">
    <parent link="link_4"/><child link="link_5"/>
