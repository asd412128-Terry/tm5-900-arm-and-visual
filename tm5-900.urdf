    <collision><geometry><mesh filename="package://tm_description/meshes/tm5-900/collision/tm5900_arm2_c.stl"/></geometry></collision>
  </link>

  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin rpy="0 0 1.570796" xyz="0.4115 0 -0.1223"/><axis xyz="0 0 1"/>
    <limit effort="43" lower="-3.141593" upper="3.141593" velocity="3.92699"/>
  </joint>

  <link name="link_4">
