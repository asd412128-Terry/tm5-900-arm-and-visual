  <link name="flange"/>
  <joint name="flange_fixed_joint" type="fixed">
    <parent link="link_6"/><child link="flange"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="flange"/><child link="gripper_base_link"/>
    <origin xyz="0 0 -0.0038" rpy="0 0 0"/> 
